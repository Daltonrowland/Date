            "S3": "repeated ambiguity maintenance materially harms pacing alignment or leaves the other person carrying definition labor",
            "S4": "sustained patterning across multiple attempts at clarification, planning, or accountability, especially with excuse churn or selective availability",
            "S5": "chronic anti-structure behavior drives repeated guarded or suppressed forecast outputs"
          }
        },
        "CL_DRIFT_SLOW": {
          "alias": "CL-103",
          "scope": "pair_state_first_with_mirrored_user_traces",
          "constants": {
            "open_above_s1_requires_drifteligibility": true,
            "s2_min_shifted_governed_drift_metrics": 2,
            "hard_clear_min_stable_windows": 2
          },
          "qualitative_rules": {
            "S1": "rollup metrics soften but remain inside watch range; no public number changes",
            "S3": "qualified deterioration persists across current window and remains directionally weaker than previous window after acute-state adjustments",
            "S4": "persistent connection erosion with weak repair recovery or continued reciprocity loss despite opportunity to stabilize",
            "S5": "prolonged and reinforced instability materially threatens pair continuity and keeps forecast in guarded or high-risk posture",
            "decay": "downgrade only after governed improvement across next qualified rollup window plus repair stabilization"
          }
        },
        "CL_PUSH_PULL": {
          "alias": "CL-104",
          "scope": "pair_state_with_mirrored_user_pattern_traces",
          "constants": {
            "s2_min_swings_in_configured_window": 2,
            "or_one_strong_swing_plus_supporting_cluster": true,
            "decay_after_steady_reciprocity_days": 21,
            "decay_requires_any": [
              "successful_repair",
              "stable_progression_marker"
            ],
            "hard_clear_after_stable_days": 60,
            "hard_clear_alt_requires": "2_qualified_stable_windows"
          },
          "qualitative_rules": {
            "S1": "one early pursue-retreat swing OR one reciprocity pattern hints at cyclic instability",
            "S3": "repeatable hot-cold rhythm visibly lowers conversation continuity or pacing alignment",
            "S4": "chronic cycling repeatedly destabilizes the pair and prevents stable repair or stable progression",
            "S5": "entrenched cycling keeps producing rupture risk and forecast suppression despite interventions"
          }
        },
        "CL_REPAIR_GAP": {
          "alias": "CL-105",
          "scope": "pair_state_first_with_user_accountability_traces",
          "constants": {
            "s2_min_unresolved_or_poorly_repaired_events_active_window": 2,
            "s2_alt": "1_significant_rupture_followed_by_no_qualifying_repair_attempt",
            "decay_after_successful_repair_and_quiet_days": 14,
            "hard_clear_after_successful_repairs": 2,
            "hard_clear_after_stable_days": 45
          },
          "qualitative_rules": {
            "S1": "one conflict or rupture event lacks timely repair and evidence is sparse",
            "S3": "repeated repair failure, apology without follow-through, or unresolved tension drags continuity and forecast quality",
            "S4": "chronic recovery collapse, issue looping, or repeated rupture without functional repair participation",
            "S5": "persistent inability to recover materially threatens connection survival and keeps rupture risk elevated",
            "do_not_clear_if": [
              "slow_drift_active",
              "hold_unstable_active"
            ]
          }
        },
        "CL_READY_OVR": {
          "alias": "CL-106",
          "scope": "individual",
          "constants": {
            "hard_clear_after_aligned_cycles": 2,
            "hard_clear_requires_no_active_supporting_cluster_above": "S2"
          },
          "qualitative_rules": {
            "S1": "self-reported readiness or serious-intent posture is materially stronger than evidence confidence, but not yet enough contradiction for persistent mismatch",
            "S2": "repeated mismatch across refreshed evidence states OR one clear mismatch combined with an active contradiction or repair-related cluster",
            "S3": "durable overstatement: user continues presenting high readiness while behavior, active clusters, or unresolved pressure clearly pull lower",
            "S4": "repeated overstatement across multiple evidence windows or product surfaces, especially if public numeric readiness would be misleading",
            "S5": "severe mismatch combined with protected states where public exposure must be suppressed until evidence stabilizes"
          }
        }
