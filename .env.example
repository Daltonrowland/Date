# Database (Railway provides this automatically)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/genesisdb
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/genesisdb

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-long-random-string

# App
ENVIRONMENT=production
APP_NAME=Relationship Scores

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.railway.app
